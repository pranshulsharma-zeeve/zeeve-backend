                        <span style="font-weight:700;color:#111827;" class="text"><t t-esc="'{:.1f}'.format(float(overall_growth)) if overall_growth else '0.0'"/>%</span>.
                      </div>
</t>

<!-- KPI cards (same as your existing) -->
<!-- ... keep your KPI HTML exactly as-is ... -->

<div style="font-family:Poppins,Arial,Helvetica,sans-serif;font-size:14px;line-height:20px;font-weight:700;color:#111827;margin-top:16px;" class="text">
                      Top Improvements
                    </div>

<t t-if="improvements">
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="border-collapse:collapse;margin-top:8px;">
<t t-foreach="improvements" t-as="improvement">
<tr>
<td width="16" valign="top" style="font-family:Arial,Helvetica,sans-serif;font-size:18px;line-height:22px;color:#FF9653;">•</td>
<td valign="top" style="font-family:Poppins,Arial,Helvetica,sans-serif;font-size:14px;line-height:22px;color:#374151;" class="text">
<t t-esc="improvement"/>
</td>
</tr>
</t>
</table>
</t>

<t t-if="not improvements">
<div style="font-family:Poppins,Arial,Helvetica,sans-serif;font-size:14px;line-height:22px;color:#374151;margin-top:8px;" class="text">
                        No improvements recorded for this period.
                      </div>
</t>

<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="border-collapse:collapse;margin-top:18px;">
<tr>
<td align="center" style="padding:12px 0 0 0;" class="btn">
<a t-att-href="frontend_url + '/reports/account-weekly'" style="font-family:Poppins,Arial,Helvetica,sans-serif;font-size:14px;font-weight:700;color:#ffffff;text-decoration:none;background:#FF9653;border-radius:10px;padding:12px 20px;display:inline-block;">
                            View Weekly Dashboard
                          </a>
</td>
</tr>
</table>

<div style="font-family:Poppins,Arial,Helvetica,sans-serif;font-size:12px;line-height:18px;color:#9ca3af;text-align:center;margin-top:10px;" class="muted">
                      Explore full trends and export data from your <a t-att-href="frontend_url + '/reports/account-weekly'" style="color:#FF9653;text-decoration:none;" class="link">dashboard</a>.
                    </div>
</td>
</tr>

<tr>
<td style="padding:16px 24px;background:#333333;" class="footer px">
<div style="font-family:Poppins,Arial,Helvetica,sans-serif;font-size:12px;line-height:18px;color:#ffffff;text-align:center;">
                      Need help? Visit our
                      <a href="https://docs.zeeve.io/" target="_blank" style="color:#FF9653;text-decoration:none;" class="link">Developer Documentation</a>
                      or
                      <a href="https://www.zeeve.io/talk-to-an-expert/" target="_blank" style="color:#FF9653;text-decoration:none;" class="link">Talk to an expert</a>.
                    </div>
</td>
</tr>

</table>
</td>
</tr>

<tr>
<td align="center" style="padding:14px 0 0 0;">
<div style="font-family:Poppins,Arial,Helvetica,sans-serif;font-size:12px;line-height:18px;color:#9ca3af;text-align:center;" class="muted">
                © 2026 Zeeve. All Rights Reserved.
              </div>
</td>
</tr>

</table>
</td>
</tr>
</table>
</body>
</html>
