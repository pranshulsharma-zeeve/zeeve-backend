<t t-set="uptime" t-value="report.get('uptime') or 0"/>
<t t-set="validator_rewards" t-value="report.get('validator_rewards') or 0"/>
<t t-set="overall_growth" t-value="report.get('overall_growth') or 0"/>
<t t-set="request_growth" t-value="report.get('request_growth') or 0"/>
<t t-set="rewards_growth" t-value="report.get('rewards_growth') or 0"/>
