    <record id="mail_template_zeeve_weekly_report" model="mail.template">
      <field name="name">Zeeve Weekly Report</field>
      <field name="model_id" ref="base.model_res_users"/>
      <field name="subject">Your Weekly Zeeve Platform Report - {{ (ctx.get('report') or {}).get('period_name', 'This Week') }}</field>
      <field name="email_from">{{ (object.env.company.email_formatted or object.env.company.email) or 'reports@zeeve.io' }}</field>
