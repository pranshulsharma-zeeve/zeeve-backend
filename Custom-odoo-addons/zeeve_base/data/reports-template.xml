                        <span style="font-weight:700;color:#111827;" class="text"><t t-esc="'{:.1f}'.format(float(uptime)) if uptime else '0.0'"/>%</span>
                        uptime. Overall growth was
                        <span style="font-weight:700;color:#111827;" class="text"><t t-esc="'{:.1f}'.format(float(overall_growth)) if overall_growth else '0.0'"/>%</span>.
                      </div>
</t>

<!-- Validator Only Content -->
<t t-if="has_validator and not has_rpc">
<div style="font-family:Poppins,Arial,Helvetica,sans-serif;font-size:14px;line-height:22px;color:#374151;margin-top:8px;" class="text">
