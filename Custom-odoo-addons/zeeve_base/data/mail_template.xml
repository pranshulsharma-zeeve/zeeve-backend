<odoo>
    <data>
       <record id="email_template_contact_us" model="mail.template">
    <field name="name">Zeeve | Contact Us — Acknowledgement</field>
    <field name="model_id" ref="model_contact_us"/>
    <field name="subject">Zeeve: We’ve received your message</field>
    <field name="email_from">{{ (object.env.company.email_formatted or object.env.company.email) or 'support@zeeve.io' }}</field>
    <field name="body_html"><![CDATA[
<t t-set="company" t-value="object.env.user.company_id or object.env['res.company'].sudo().search([], limit=1)"/>
<t t-set="base_url" t-value="(env['ir.config_parameter'].sudo().get_param('web.base.url') or '').rstrip('/') or 'https://your-domain.example'"/>
<t t-set="logo_url" t-value="base_url + ('/web/image/res.company/%s/logo' % (company.id or 1))"/>

<!-- Pull dynamic links from your own config model -->
<t t-set="cfg" t-value="env['zeeve.config'].sudo().search([], limit=1)"/>
<t t-set="link_x"         t-value="(cfg and cfg.twitter_url)   or 'https://x.com/0xZeeve'"/>
<t t-set="link_linkedin"  t-value="(cfg and cfg.linkedin_url)  or 'https://www.linkedin.com/company/0xzeeve/'"/>
<t t-set="link_telegram"  t-value="(cfg and cfg.telegram_url)  or 'https://t.me/ZeeveDeeptech'"/>

<table align="center" border="0" cellpadding="0" cellspacing="0">
  <tr>
    <td style="padding:5px">
      <table align="center" border="0" cellpadding="0" cellspacing="0" style="border: 1px solid #e9e9e9; background: #ffffff;" bgcolor="#ffffff">
        <tr>
          <td style="padding:24px 24px 10px 24px;">
            <table align="center" border="0" cellpadding="0" cellspacing="0">
              <tr>
                <td>
                  <img t-att-src="logo_url" alt="Zeeve" height="100"/>
                </td>
              </tr>

              <tr>
                <td style="padding:10px 0 16px;">
                  <p style="font-size:20px; line-height:30px; font-weight:500; font-family:Poppins,Arial,Helvetica,sans-serif; margin:0;">
                    <strong>Hi <t t-out="(object.name or object.email or '').split(' ')[0]"/> ,</strong>
                  </p>
                </td>
              </tr>

              <tr>
                <td style="padding:0 0 16px;">
                  <p style="font-size:18px; line-height:28px; font-weight:400; font-family:Poppins,Arial,Helvetica,sans-serif; margin:0;">
                    Thanks for reaching out to Zeeve. We’ve received your message and our team will get back to you shortly.
                  </p>
                </td>
              </tr>

              <tr>
                <td style="padding:30px 0 10px;">
                  <p style="font-size:16px; color:#FF9653; line-height:26px; font-weight:600; font-family:Poppins,Arial,Helvetica,sans-serif; margin:0; text-transform:uppercase; letter-spacing:5px;">
                    Your submission
                  </p>
                </td>
              </tr>

              <!-- Details block -->
              <tr>
                <td style="padding:0 0 16px;">
                  <table width="100%" cellpadding="0" cellspacing="0" style="border-collapse:collapse;">
                    <tr>
                      <td style="padding:8px 0; width:120px; font-size:16px; font-weight:600; font-family:Poppins,Arial,Helvetica,sans-serif; color:#232323;">Name</td>
                      <td style="padding:8px 0; font-size:16px; font-family:Poppins,Arial,Helvetica,sans-serif; color:#232323;">
                        <span t-field="object.name"/>
                      </td>
                    </tr>
                    <tr>
                      <td style="padding:8px 0; width:120px; font-size:16px; font-weight:600; font-family:Poppins,Arial,Helvetica,sans-serif; color:#232323;">Email</td>
                      <td style="padding:8px 0; font-size:16px; font-family:Poppins,Arial,Helvetica,sans-serif; color:#232323;">
                        <t t-esc="object.email"/>
                      </td>
                    </tr>
                    <tr>
                      <td style="padding:8px 0; width:120px; font-size:16px; font-weight:600; font-family:Poppins,Arial,Helvetica,sans-serif; color:#232323; vertical-align:top;">Message</td>
                      <td style="padding:8px 0; font-size:16px; line-height:24px; font-family:Poppins,Arial,Helvetica,sans-serif; color:#232323;">
                        <t t-esc="object.comment"/>
                      </td>
                    </tr>
                    <tr>
                      <td style="padding:8px 0; width:120px; font-size:16px; font-weight:600; font-family:Poppins,Arial,Helvetica,sans-serif; color:#232323; vertical-align:top;">Type</td>
                      <td style="padding:8px 0; font-size:16px; line-height:24px; font-family:Poppins,Arial,Helvetica,sans-serif; color:#232323;">
                        <t t-esc="object.type"/>
                      </td>
                    </tr>
                    <tr>
                      <td style="padding:8px 0; width:120px; font-size:16px; font-weight:600; font-family:Poppins,Arial,Helvetica,sans-serif; color:#232323; vertical-align:top;">Company</td>
                      <td style="padding:8px 0; font-size:16px; line-height:24px; font-family:Poppins,Arial,Helvetica,sans-serif; color:#232323;">
                        <t t-esc="object.company_name"/>
                      </td>
                    </tr>
                  </table>
                </td>
              </tr>

              <tr>
                <td style="padding:20px 0 0;">
                  <p style="font-size:18px; line-height:28px; font-weight:400; font-family:Poppins,Arial,Helvetica,sans-serif; margin:0; color:#FF9653;">
                    <strong>While you wait:</strong>
                  </p>
                </td>
              </tr>

              <tr>
                <td style="padding:8px 0 16px;">
                  <p style="font-size:16px; line-height:26px; font-weight:500; font-family:Poppins,Arial,Helvetica,sans-serif; margin:0;">
                    Explore our
                    <a href="https://docs.zeeve.io/" style="color:#FF9653; text-decoration:none;">Developer Documentation</a>
                    or schedule a call with our experts.
                  </p>
                </td>
              </tr>

              <tr>
                <td style="padding:0 10px 24px 0;">
                  <table align="left" border="0" cellpadding="0" cellspacing="0" style="max-width:200px; width:200px;" width="200">
                    <tr>
                      <td bgcolor="#ffffff" style="padding:15px 10px 15px 0; background:#ffffff; text-align:center">
                        <a href="https://www.zeeve.io/talk-to-an-expert/" style="font-family:Poppins, Arial, Helvetica, sans-serif; text-align:center; text-decoration:none; display:block; background-color:#FF9653; font-size:15px; line-height:46px; height:46px; color:#ffffff; font-weight:700; border-radius:0; border:0 solid #FF9653; white-space:nowrap; text-transform:uppercase;">Schedule a Call</a>
                      </td>
                    </tr>
                  </table>
                </td>
              </tr>

              <tr>
                <td style="padding:0 24px 0 0;">
                  <p style="font-size:18px; color:#232323; line-height:28px; font-weight:500; font-family:Poppins,Arial,Helvetica,sans-serif; margin:0;">
                    Warm regards,<br/>
                    <strong>Team Zeeve</strong>
                  </p>
                </td>
              </tr>
            </table>
          </td>
        </tr>

        <!-- Footer (same style as Welcome) -->
        <tr>
          <td>
            <table bgcolor="#ffffff" width="100%" align="center" border="0" cellpadding="0" cellspacing="0" style="background-color:#ffffff;">
              <tr>
                <td style="padding:40px 24px 15px; text-align:center">
                  <p style="font-size:16px; line-height:26px; font-weight:600; color:#FF9653; font-family:Poppins,Arial,Helvetica,sans-serif; margin:0; text-transform:uppercase; letter-spacing:5px;">Follow us at</p>
                </td>
              </tr>
              <tr>
                <td style="padding:0 24px; text-align:center">
                  <a t-att-href="link_x"><img src="https://demo.studiobrahma.in/zeeve/mailer/images/twitter1.png?v=1" width="40" alt="twitter" style="margin-right:20px;"/></a>
                  <a t-att-href="link_linkedin"><img src="https://demo.studiobrahma.in/zeeve/mailer/images/linkedin1.png?v=1" width="40" alt="linkedIn" style="margin-right:20px;"/></a>
                  <a t-att-href="link_telegram"><img src="https://demo.studiobrahma.in/zeeve/mailer/images/telegram1.png?v=1" width="40" alt="telegram"/></a>
                </td>
              </tr>
              <tr>
                <td style="padding:30px 24px 48px; text-align:center">
                  <p style="font-size:14px; color:#232323; line-height:24px; font-weight:400; font-family:Poppins,Arial,Helvetica,sans-serif; margin:0;">© <t t-out="(company.name or 'Zeeve')"/> <t t-out="datetime.date.today().year"/>. All Rights Reserved</p>
                </td>
              </tr>
            </table>
          </td>
        </tr>

      </table>
    </td>
  </tr>
</table>
    ]]></field>

    <field name="auto_delete" eval="True"/>
</record>

