        <!-- Footer (same as Welcome) -->
        <tr>
          <td>
            <table bgcolor="#ffffff" width="100%" align="center" border="0" cellpadding="0" cellspacing="0" style="background-color:#ffffff;">
              <tr>
                <td style="padding:40px 24px 15px; text-align:center">
