<odoo>
    <data>
        <record id="view_zeeve_config_tree" model="ir.ui.view">
            <field name="name">zeeve.config.list</field>
            <field name="model">zeeve.config</field>
            <field name="arch" type="xml">
                <list string="Zeeve Configurations">
                    <field name="admin_emails"/>
                    <field name="twitter_url"/>
                    <field name="linkedin_url"/>
                    <field name="telegram_url"/>
                    <field name="network_type_ids" widget="many2many_tags"/>
                </list>
            </field>
        </record>
        <record id="view_zeeve_config_form" model="ir.ui.view">
            <field name="name">zeeve.config.form</field>
            <field name="model">zeeve.config</field>
            <field name="arch" type="xml">
                <form string="Zeeve Configuration">
                    <sheet>
                        <group>
                            <field name="admin_emails"/>
                            <field name="support_email"/>
                            <field name="twitter_url"/>
                            <field name="linkedin_url"/>
                            <field name="telegram_url"/>
                            <field name="network_type_ids" widget="many2many_tags"/>
                        </group>
                        <notebook>
                            <page string="Admin Channels">
                                <field name="admin_channel_ids"
                                    context="{'default_config_id': id}"
                                    domain="[('config_id', '=', id)]"/>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>
        <record id="action_zeeve_config" model="ir.actions.act_window">
            <field name="name">Zeeve Configuration</field>
            <field name="res_model">zeeve.config</field>
            <field name="view_mode">list,form</field>
            <field name="groups_id" eval="[(6, 0, [ref('access_rights.group_admin'), ref('access_rights.group_technical_manager'), ref('access_rights.group_support_staff_manager'), ref('access_rights.group_support_staff')])]"/>
        </record>
        <menuitem id="menu_zeeve_config" name="General Configuration" parent="menu_zeeve_base_root" action="action_zeeve_config" sequence="30" groups="access_rights.group_admin,access_rights.group_technical_manager,access_rights.group_support_staff_manager,access_rights.group_support_staff"/>
    </data>
</odoo>
