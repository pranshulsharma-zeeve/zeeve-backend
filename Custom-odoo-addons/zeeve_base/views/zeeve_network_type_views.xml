<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="view_zeeve_network_type_tree" model="ir.ui.view">
            <field name="name">zeeve.network.type.tree</field>
            <field name="model">zeeve.network.type</field>
            <field name="arch" type="xml">
                <list string="Network Types">
                    <field name="name"/>
                    <field name="code"/>
                </list>
            </field>
        </record>

        <record id="view_zeeve_network_type_form" model="ir.ui.view">
            <field name="name">zeeve.network.type.form</field>
            <field name="model">zeeve.network.type</field>
            <field name="arch" type="xml">
                <form string="Network Type">
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                        </group>
                        <group>
                            <field name="description"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_zeeve_network_type" model="ir.actions.act_window">
            <field name="name">Network Types</field>
            <field name="res_model">zeeve.network.type</field>
            <field name="view_mode">list,form</field>
            <field name="groups_id" eval="[(6, 0, [ref('access_rights.group_admin'), ref('access_rights.group_technical_manager'), ref('access_rights.group_support_staff_manager'), ref('access_rights.group_support_staff')])]"/>
        </record>

        <menuitem id="menu_zeeve_network_type" name="Network Types" parent="menu_zeeve_base_root"
                  action="action_zeeve_network_type" sequence="40"
                  groups="access_rights.group_admin,access_rights.group_technical_manager,access_rights.group_support_staff_manager,access_rights.group_support_staff"/>
    </data>
</odoo>
