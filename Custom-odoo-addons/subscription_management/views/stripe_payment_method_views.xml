<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_stripe_payment_method_tree" model="ir.ui.view">
        <field name="name">stripe.payment.method.tree</field>
        <field name="model">stripe.payment.method</field>
        <field name="arch" type="xml">
            <list string="Stripe Payment Methods">
                <field name="partner_id"/>
                <field name="brand"/>
                <field name="last4"/>
                <field name="exp_month"/>
                <field name="exp_year"/>
                <field name="is_default"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_stripe_payment_method_form" model="ir.ui.view">
        <field name="name">stripe.payment.method.form</field>
        <field name="model">stripe.payment.method</field>
        <field name="arch" type="xml">
            <form string="Stripe Payment Method">
                <sheet>
                    <group>
                        <group>
                            <group>
                                <field name="partner_id"/>
                                <field name="stripe_payment_method_id" readonly="1"/>
                                <field name="is_default"/>
                                <field name="active"/>
                            </group>
                            <group>
                                <field name="brand" readonly="1"/>
                                <field name="last4" readonly="1"/>
                                <field name="exp_month" readonly="1"/>
                                <field name="exp_year" readonly="1"/>
                            </group>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_stripe_payment_method" model="ir.actions.act_window">
        <field name="name">Stripe Payment Methods</field>
        <field name="res_model">stripe.payment.method</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_stripe_payment_method"
              name="Payment Methods Vault"
              parent="subscription_management.menu_sale_subscription_config"
              action="action_stripe_payment_method"
              sequence="20"/>
</odoo>
