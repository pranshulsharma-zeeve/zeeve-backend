<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Tree View -->
        <record id="view_validator_rewards_queue_tree" model="ir.ui.view">
            <field name="name">validator.rewards.queue.tree</field>
            <field name="model">validator.rewards.queue</field>
            <field name="arch" type="xml">
                <list string="Validator Rewards Queue" default_order="create_date asc">
                    <field name="valoper"/>
                    <field name="protocol_id"/>
                    <field name="state" decoration-info="state == 'pending'" 
                           decoration-warning="state == 'processing'" 
                           decoration-success="state == 'completed'"
                           decoration-danger="state == 'failed'"/>
                    <field name="create_date"/>
                    <field name="last_attempt_date"/>
                    <field name="last_snapshot_date"/>
                    <field name="error_message"/>
                    <field name="node_id"/>
                </list>
            </field>
        </record>

        <!-- Form View -->
        <record id="view_validator_rewards_queue_form" model="ir.ui.view">
            <field name="name">validator.rewards.queue.form</field>
            <field name="model">validator.rewards.queue</field>
            <field name="arch" type="xml">
                <form string="Validator Rewards Queue">
                    <header>
                        <field name="state" widget="statusbar" statusbar_visible="pending,processing,completed,failed"/>
                    </header>
                    <sheet>
                        <group>
                            <group string="Validator Information">
                                <field name="valoper"/>
                                <field name="protocol_id"/>
                                <field name="rpc_url"/>
                                <field name="node_id"/>
                            </group>
                            <group string="Status">
                                <field name="state"/>
                                <field name="create_date"/>
                                <field name="last_attempt_date"/>
                                <field name="last_snapshot_date"/>
                            </group>
                        </group>
                        <group string="Error Details" invisible="state != 'failed'">
                            <field name="error_message" nolabel="1"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Search View with Filters -->
        <record id="view_validator_rewards_queue_search" model="ir.ui.view">
            <field name="name">validator.rewards.queue.search</field>
            <field name="model">validator.rewards.queue</field>
            <field name="arch" type="xml">
                <search string="Search Validator Rewards Queue">
                    <field name="valoper"/>
                    <field name="protocol_id"/>
                    <field name="state"/>
                    <separator/>
                    <filter string="Pending" name="filter_pending" domain="[('state', '=', 'pending')]"/>
                    <filter string="Processing" name="filter_processing" domain="[('state', '=', 'processing')]"/>
                    <filter string="Completed" name="filter_completed" domain="[('state', '=', 'completed')]"/>
                    <filter string="Failed" name="filter_failed" domain="[('state', '=', 'failed')]"/>
                    <separator/>
                    <group expand="0" string="Group By">
                        <filter string="State" name="group_state" context="{'group_by': 'state'}"/>
                        <filter string="Protocol" name="group_protocol" context="{'group_by': 'protocol_id'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- Action -->
        <record id="action_validator_rewards_queue" model="ir.actions.act_window">
            <field name="name">Validator Rewards Queue</field>
            <field name="res_model">validator.rewards.queue</field>
            <field name="view_mode">list,form</field>
            <field name="view_id" ref="view_validator_rewards_queue_tree"/>
            <field name="search_view_id" ref="view_validator_rewards_queue_search"/>
            <field name="context">{'search_default_filter_pending': 1}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    No validators in queue
                </p>
                <p>
                    Click the "Populate Queue" button to add validators from active nodes.
                </p>
            </field>
        </record>

        <!-- Menu Item under Subscription Configuration (next to Validator Rewards) -->
        <menuitem id="menu_validator_rewards_queue"
                  name="Validator Rewards Queue"
                  parent="menu_sale_subscription_config"
                  action="action_validator_rewards_queue"
                  sequence="62"
                  groups="access_rights.group_admin,access_rights.group_technical_manager,access_rights.group_support_staff_manager"/>
    </data>
</odoo>
