<odoo>
    <record id="view_subscription_invoice_queue_tree" model="ir.ui.view">
        <field name="name">subscription.invoice.queue.tree</field>
        <field name="model">subscription.invoice.queue</field>
        <field name="arch" type="xml">
            <list string="Subscription Invoice Queue" create="false">
                <field name="subscription_id"/>
                <field name="stripe_event_id"/>
                <field name="processed"/>
                <field name="attempt_count"/>
                <field name="invoice_id"/>
            </list>
        </field>
    </record>

    <record id="view_subscription_invoice_queue_form" model="ir.ui.view">
        <field name="name">subscription.invoice.queue.form</field>
        <field name="model">subscription.invoice.queue</field>
        <field name="arch" type="xml">
            <form string="Subscription Invoice Queue">
                <sheet>
                    <group>
                        <field name="subscription_id"/>
                        <field name="invoice_id"/>
                        <field name="processed"/>
                        <field name="stripe_event_id"/>
                        <field name="error_message"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_subscription_invoice_queue" model="ir.actions.act_window">
        <field name="name">Subscription Invoice Queue</field>
        <field name="res_model">subscription.invoice.queue</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p>This shows all queued invoices waiting to be processed.</p>
        </field>
    </record>
    <menuitem id="menu_subscription_invoice_queue"
              name="Subscription Invoice Queue"
              parent="subscription_management.menu_subscription_management_root"
              action="action_subscription_invoice_queue" groups="access_rights.group_admin,access_rights.group_technical_manager"/>


</odoo>
