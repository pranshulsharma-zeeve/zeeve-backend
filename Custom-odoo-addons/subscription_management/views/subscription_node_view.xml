<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_subscription_node_search" model="ir.ui.view">
            <field name="name">subscription.node.search</field>
            <field name="model">subscription.node</field>
            <field name="arch" type="xml">
                <search string="Subscription Nodes">
                    <field name="node_name" string="Node Name"/>
                    <field name="node_identifier" string="Node Identifier"/>
                    <field name="customer_email" string="Customer Email"/>
                    <field name="subscription_id"/>
                    <field name="node_type"/>
                    <field name="state"/>
                    <filter string="Ready" name="filter_ready" domain="[('state', '=', 'ready')]"/>
                    <filter string="Provisioning" name="filter_provisioning" domain="[('state', '=', 'provisioning')]"/>
                </search>
            </field>
        </record>

        <record id="view_subscription_node_tree" model="ir.ui.view">
            <field name="name">subscription.node.tree</field>
            <field name="model">subscription.node</field>
            <field name="arch" type="xml">
                <list string="Subscription Nodes" default_order="create_date desc" decoration-success="state == 'ready'" decoration-warning="state in ('provisioning', 'requested', 'syncing')">
                    <field name="node_name"/>
                    <field name="subscription_id" options="{'no_create': True}"/>
                    <field name="node_type"/>
                    <field name="state"/>
                    <field name="network_selection_id"/>
                    <field name="server_location_id"/>
                    <field name="endpoint_url"/>
                    <field name="node_identifier"/>
                    <field name="node_created_date"/>
                    <field name="invoice_count" string="Invoices"/>
                </list>
            </field>
        </record>

        <record id="view_subscription_node_form" model="ir.ui.view">
            <field name="name">subscription.node.form</field>
            <field name="model">subscription.node</field>
            <field name="arch" type="xml">
                <form string="Subscription Node">
                    <header>
                        <button name="action_reject_cancellation_request" type="object" string="Reject Cancellation" class="oe_highlight" invisible="state != 'cancellation_requested'"/>
                    </header>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button name="action_view_node_invoices" type="object" class="oe_stat_button" icon="fa-file-text-o">
                                <field name="invoice_count" widget="statinfo" string="Invoices"/>
                            </button>
                            <button name="get_wallet_info" type="object" string="Get Wallet Info" class="oe_stat_button" icon="fa-wallet" invisible="true"/>
                        </div>
                        <group>
                            <group string="General Information">
                                <field name="node_name"/>
                                <field name="subscription_id" options="{'no_create': True}" readonly="1"/>
                                <field name="node_identifier" readonly="1"/>
                                <field name="is_vision_onboarded"/>
                                <field name="node_created_date"/>

                            </group>
                            <group string="Node Details">
                                <field name="state"/>
                                <field name="node_type"/>
                                <field name="endpoint_url"/>
                                <field name="network_selection_id"/>
                                <field name="server_location_id"/>
                                <field name="software_update_rule"/>
                            </group>
                        </group>
                        <group string="Metadata">
                            <field name="metadata_json" widget="json"/>
                            <field name="validator_info" widget="json"/>
                        </group>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <record id="action_subscription_nodes" model="ir.actions.act_window">
            <field name="name">Subscription Nodes</field>
            <field name="res_model">subscription.node</field>
            <field name="view_mode">list,form</field>
            <field name="view_id" ref="view_subscription_node_tree"/>
            <field name="search_view_id" ref="view_subscription_node_search"/>
        </record>

        <menuitem id="menu_subscription_nodes" name="Subscription Nodes" parent="subscription_management.menu_subscription_management_root" action="action_subscription_nodes" sequence="20" groups="access_rights.group_admin,access_rights.group_technical_manager,access_rights.group_support_staff,access_rights.group_support_staff_manager"/>
    </data>
</odoo>
