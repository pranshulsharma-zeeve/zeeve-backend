<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Add discount fields to subscription form view -->
        <record id="subscription_subscription_form_view_discount" model="ir.ui.view">
            <field name="name">subscription.subscription.form.discount</field>
            <field name="model">subscription.subscription</field>
            <field name="inherit_id" ref="subscription_management.subscription_subscription_form_view"/>
            <field name="arch" type="xml">
                <xpath expr="//group[@name='stripe']" position="before">
                    <group string="Discount Information" modifiers="{'invisible': [('discount_id', '=', False)]}">
                        <group>
                            <field name="discount_id" readonly="1"/>
                            <field name="discount_code" readonly="1"/>
                        </group>
                        <group>
                            <field name="original_price" readonly="1"/>
                            <field name="discount_amount" readonly="1"/>
                        </group>
                    </group>
                </xpath>
            </field>
        </record>

        <!-- Add discount fields to subscription tree view -->
        <record id="subscription_subscription_tree_view_discount" model="ir.ui.view">
            <field name="name">subscription.subscription.tree.discount</field>
            <field name="model">subscription.subscription</field>
            <field name="inherit_id" ref="subscription_management.subscription_list_view"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='payment_frequency']" position="after">
                    <field name="discount_code" optional="hide"/>
                    <field name="discount_amount" optional="hide"/>
                </xpath>
            </field>
        </record>

    </data>
</odoo>
