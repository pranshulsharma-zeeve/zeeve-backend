<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Cron job to snapshot validator rewards every 6 hours -->
        <record id="cron_snapshot_validator_rewards" model="ir.cron">
            <field name="name">Snapshot Validator Rewards</field>
            <field name="model_id" ref="model_validator_rewards_snapshot"/>
            <field name="state">code</field>
            <field name="code">model.snapshot_all_validators_rewards()</field>
            <field name="interval_number">6</field>
            <field name="interval_type">hours</field>
            <field name="active" eval="True"/>
        </record>
    </data>
</odoo>
