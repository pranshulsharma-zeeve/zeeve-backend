<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Cron job to populate validator performance queue daily -->
        <record id="cron_populate_validator_performance_queue" model="ir.cron">
            <field name="name">Populate Validator Performance Queue</field>
            <field name="model_id" ref="model_validator_performance_queue"/>
            <field name="state">code</field>
            <field name="code">model.populate_performance_queue()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
        </record>
    </data>
</odoo>
