        <tr>
          <td style="padding:24px 24px 10px 24px;">
            <table align="center" border="0" cellpadding="0" cellspacing="0">
              <tr>
                <td>
                  <a href="https://www.zeeve.io/">
                    <t t-if="company_logo">
                      <img t-att-src="company_logo" alt="Zeeve" height="80"/>
                    </t>
                    <t t-else="">
                      <img src="https://demo.studiobrahma.in/zeeve/mailer/images/zeeve-logo2.png" alt="Zeeve" height="80"/>
                    </t>
                  </a>
                </td>
              </tr>
              <tr>
                <td style="padding:18px 0 12px;">
                  <p style="font-size:20px;line-height:30px;font-weight:600;font-family:Poppins,Arial,Helvetica,sans-serif;margin:0;color:#c87f0a;">
                    <strong>Manual payment required</strong>
                  </p>
                </td>
              </tr>
              <tr>
                <td style="padding:0 0 18px;">
                  <p style="font-size:17px;line-height:26px;font-weight:400;font-family:Poppins,Arial,Helvetica,sans-serif;margin:0;">
                    Hi <t t-out="customer_name"/>, automatic collection is not active for <strong><t t-out="protocol_name"/></strong> because the subscription is <strong><t t-out="manual_payment_reason"/></strong>. Please complete the renewal payment manually for the invoice due on <strong><t t-out="due_date_display"/></strong>.
                  </p>
                </td>
              </tr>
              <tr>
                <td style="padding:20px 0 16px;">
                  <p style="font-size:15px;color:#FF9653;line-height:24px;font-weight:600;font-family:Poppins,Arial,Helvetica,sans-serif;margin:0;text-transform:uppercase;letter-spacing:4px;">Manual Payment Snapshot</p>
                </td>
              </tr>
              <tr>
                <td style="padding:0 0 10px;">
                  <table width="100%" border="0" cellpadding="0" cellspacing="0">
                    <tr>
                      <td style="padding:0 12px 12px 0;vertical-align:top;width:24px;"><p style="font-size:18px;line-height:28px;font-weight:600;font-family:Poppins,Arial,Helvetica,sans-serif;color:#FF9653;margin:0;">&#9679;</p></td>
                      <td style="padding:0 0 12px 0;"><p style="font-size:17px;line-height:24px;font-weight:500;font-family:Poppins,Arial,Helvetica,sans-serif;margin:0;">Amount due: <t t-out="formatted_amount"/></p></td>
                    </tr>
                    <tr>
                      <td style="padding:0 12px 12px 0;vertical-align:top;width:24px;"><p style="font-size:18px;line-height:28px;font-weight:600;font-family:Poppins,Arial,Helvetica,sans-serif;color:#FF9653;margin:0;">&#9679;</p></td>
                      <td style="padding:0 0 12px 0;"><p style="font-size:17px;line-height:24px;font-weight:500;font-family:Poppins,Arial,Helvetica,sans-serif;margin:0;">Reason: <t t-out="manual_payment_reason"/></p></td>
                    </tr>
                    <tr>
                      <td style="padding:0 12px 12px 0;vertical-align:top;width:24px;"><p style="font-size:18px;line-height:28px;font-weight:600;font-family:Poppins,Arial,Helvetica,sans-serif;color:#FF9653;margin:0;">&#9679;</p></td>
                      <td style="padding:0 0 12px 0;"><p style="font-size:17px;line-height:24px;font-weight:500;font-family:Poppins,Arial,Helvetica,sans-serif;margin:0;">Due date: <t t-out="due_date_display"/></p></td>
                    </tr>
                  </table>
                </td>
              </tr>
              <tr>
                <td style="padding:12px 0 24px;">
                  <t t-if="invoice_url">
                    <a t-att-href="invoice_url" style="display:inline-block;padding:12px 28px;background:#c87f0a;color:#ffffff;font-size:15px;font-weight:600;font-family:Poppins,Arial,Helvetica,sans-serif;border-radius:6px;text-decoration:none;">Review invoice &amp; pay</a>
                  </t>
                </td>
              </tr>
              <tr>
                <td style="padding:0 0 18px;">
                  <p style="font-size:16px;line-height:26px;font-weight:400;font-family:Poppins,Arial,Helvetica,sans-serif;margin:0;">
                    Once payment is completed, Zeeve will continue the renewal flow normally. If you need billing assistance, contact <a t-att-href="'mailto:%s' % support_email" style="color:#FF9653;text-decoration:none;"><t t-out="support_email"/></a>.
                  </p>
                </td>
              </tr>
              <tr>
                <td style="padding:0 0 24px;">
                  <p style="font-size:17px;line-height:26px;font-weight:500;font-family:Poppins,Arial,Helvetica,sans-serif;margin:0;">Best,<br/>The Zeeve Team</p>
                </td>
              </tr>
            </table>
          </td>
        </tr>
      </table>
    </td>
  </tr>
</table>
      ]]></field>
    </record>
