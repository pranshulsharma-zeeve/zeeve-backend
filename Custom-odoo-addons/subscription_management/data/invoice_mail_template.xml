<?xml version="1.0" encoding="utf-8"?>

<odoo>
    <record id="email_template_custom_invoice" model="mail.template">
        <field name="name">Zeeve Custom Invoice Email</field>
        <field name="model_id" ref="model_account_move"/>
        <field name="subject">Your Invoice {{ object.name }}</field>
        <field name="body_html"><![CDATA[
            <p>Hello {{ object.customer_id.name }},</p>
            <p>Here is your invoice <strong>{{ object.name }}</strong>.</p>
            <p>Total: {{ object.total }} {{ object.currency_id.symbol }}</p>
            <p>Balance Due: {{ object.balance_due }} {{ object.currency_id.symbol }}</p>
            <p>Thank you,<br/>Zeeve Team</p>
        ]]></field>
        <field name="report_id" ref="subscription_management.action_report_custom_invoice_account"/>
        <field name="report_name">Invoice_{{ object.name }}</field>
    </record>
</odoo>





