<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <!-- Cron job to snapshot validator performance every 6 hours -->
        <record id="cron_snapshot_validator_performance" model="ir.cron">
            <field name="name">Snapshot Validator Performance</field>
            <field name="model_id" ref="model_validator_performance_snapshot"/>
            <field name="state">code</field>
            <field name="code">model.snapshot_all_validator_performance()</field>
            <field name="interval_number">6</field>
            <field name="interval_type">hours</field>
            <field name="active" eval="True"/>
        </record>
    </data>
</odoo>
