                    <img t-att-src="logo_url" alt="OPN" height="100"/>
                  </a>
                </td>
              </tr>
              <tr>
                <td style="padding:10px 0 16px;">
                  <p style="font-size:20px; line-height:30px; font-weight:500; font-family:Poppins,Arial,Helvetica,sans-serif; padding:0; margin:0; color:#222;">
                    <strong>Hi <t t-out="contact_name.split(' ')[0] if isinstance(contact_name, str) else contact_name"/>,</strong>
                  </p>
                </td>
              </tr>
              <tr>
                <td style="padding:0 0 16px;">
                  <p style="font-size:18px; line-height:28px; font-weight:400; font-family:Poppins,Arial,Helvetica,sans-serif; padding:0; margin:0; color:#222;">
                    <strong>Welcome to OPN! To complete your registration, please use the OTP below:</strong>
                  </p>
