<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data noupdate="1">
        <record id="rule_rollup_service_user_own" model="ir.rule">
            <field name="name">Rollup Services: users see own records</field>
            <field name="model_id" ref="model_rollup_service"/>
            <field name="domain_force">[("create_uid", "=", user.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="rule_rollup_service_admin_all" model="ir.rule">
            <field name="name">Rollup Services: administrators see all records</field>
            <field name="model_id" ref="model_rollup_service"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('base.group_system'))]"/>
        </record>

        <record id="rule_rollup_node_user_own" model="ir.rule">
            <field name="name">Rollup Nodes: users see own service nodes</field>
            <field name="model_id" ref="model_rollup_node"/>
            <field name="domain_force">[("service_id.create_uid", "=", user.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        </record>
    </data>
</odoo>
