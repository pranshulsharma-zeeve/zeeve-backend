<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="action_rollup_type" model="ir.actions.act_window">
            <field name="name">Rollup Types</field>
            <field name="res_model">rollup.type</field>
            <field name="view_mode">list,form</field>
        </record>

        <record id="action_rollup_type_services" model="ir.actions.act_window">
            <field name="name">Rollup Services</field>
            <field name="res_model">rollup.service</field>
            <field name="view_mode">kanban,list,form</field>
            <field name="domain">[("type_id", "=", active_id)]</field>
            <field name="context">{'default_type_id': active_id}</field>
        </record>

        <menuitem id="menu_rollup_configuration" name="Configuration" parent="rollup_management.menu_rollup_root" sequence="20" groups="access_rights.group_admin,access_rights.group_technical_manager,access_rights.group_support_staff,access_rights.group_support_staff_manager"/>
        <menuitem id="menu_rollup_types" name="Rollup Types" parent="menu_rollup_configuration" action="action_rollup_type" sequence="10" groups="access_rights.group_admin,access_rights.group_technical_manager,access_rights.group_support_staff,access_rights.group_support_staff_manager"/>

        <record id="view_rollup_type_tree" model="ir.ui.view">
            <field name="name">rollup.type.tree</field>
            <field name="model">rollup.type</field>
            <field name="arch" type="xml">
                <list string="Rollup Types">
                    <field name="name"/>
                    <field name="related_product_id"/>
                    <field name="default_region_ids" widget="many2many_tags"/>
                    <field name="allow_custom_token" widget="boolean_button"/>
                    <field name="cost"/>
                    <field name="payment_frequency"/>
                </list>
            </field>
        </record>

        <record id="view_rollup_type_form" model="ir.ui.view">
            <field name="name">rollup.type.form</field>
            <field name="model">rollup.type</field>
            <field name="arch" type="xml">
                <form string="Rollup Type">
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button name="%(rollup_management.action_rollup_type_services)d" type="action" class="oe_stat_button" icon="fa-sitemap" context="{'default_type_id': id}">
                                <field name="service_count" widget="statinfo" string="Services"/>
                            </button>
                            <button name="action_sync_with_stripe" type="object" string="Sync with Stripe" class="oe_stat_button" icon="fa-refresh" groups="base.group_system"/>
                        </div>
                        <group>
                            <group>
                                <field name="image" widget="image"/>
                                <field name="name"/>
                                <field name="related_product_id" options="{'no_create': True}"/>
                                <field name="stripe_product_id" readonly="1" groups="base.group_system"/>
                                <field name="stripe_price_id" readonly="1" groups="base.group_system"/>
                                <field name="admin_channel_id" options="{'no_create': False}" domain="[('active','=',True)]"/>
                            </group>
                            <group>
                                <field name="docs" widget="url" placeholder="https://"/>
                                <field name="rollup_id"/>

                            </group>
                        </group>
                        <notebook>
                            <page string="Overview">
                                <group>
                                    <field name="description" widget="html"/>
                                </group>
                            </page>
                            <page string="Deployment">
                                <group>
                                    <field name="default_region_ids" widget="many2many_tags" options="{'no_create': True}"/>
                                    <field name="allow_custom_token"/>
                                    <field name="cost"/>
                                    <field name="amount_month"/>
                                    <field name="amount_quarter"/>
                                    <field name="amount_year"/>
                                    <field name="payment_frequency"/>
                                </group>
                            </page>
                            <page string="Ecosystem">
                                <group>
                                    <field name="data_availability_ids" widget="many2many_tags"/>
                                    <field name="settlement_layer_ids" widget="many2many_tags"/>
                                    <field name="sequencer_ids" widget="many2many_tags"/>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <record id="view_rollup_type_search" model="ir.ui.view">
            <field name="name">rollup.type.search</field>
            <field name="model">rollup.type</field>
            <field name="arch" type="xml">
                <search string="Search Rollup Types">
                    <field name="name"/>
                    <field name="default_region_ids"/>
                    <field name="related_product_id"/>
                    <filter name="filter_custom_token" string="Custom Token" domain="[('allow_custom_token', '=', True)]"/>
                </search>
            </field>
        </record>
    </data>
</odoo>
