<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="action_rollup_node" model="ir.actions.act_window">
            <field name="name">Rollup Nodes</field>
            <field name="res_model">rollup.node</field>
            <field name="view_mode">list,form</field>
            <field name="context">{'search_default_status_running': 1}</field>
        </record>

        <menuitem id="menu_rollup_nodes" name="Nodes" parent="rollup_management.menu_rollup_root" action="action_rollup_node" sequence="20" groups="access_rights.group_admin,access_rights.group_technical_manager,access_rights.group_support_staff,access_rights.group_support_staff_manager"/>

        <record id="view_rollup_node_tree" model="ir.ui.view">
            <field name="name">rollup.node.tree</field>
            <field name="model">rollup.node</field>
            <field name="arch" type="xml">
                <list string="Rollup Nodes">
                    <field name="node_name"/>
                    <field name="nodid"/>
                    <field name="service_id"/>
                    <field name="node_type"/>
                    <field name="status" widget="badge"/>
                    <field name="endpoint_url"/>
                </list>
            </field>
        </record>

        <record id="view_rollup_node_form" model="ir.ui.view">
            <field name="name">rollup.node.form</field>
            <field name="model">rollup.node</field>
            <field name="arch" type="xml">
                <form string="Rollup Node">
                    <sheet>
                        <group>
                            <group>
                                <field name="node_name"/>
                                <field name="nodid"/>
                                <field name="endpoint_url"/>

                            </group>
                            <group>
                                <field name="service_id"/>
                                <field name="status"/>
                                <field name="node_type"/>
                                <field name="node_created_date"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Metadata">
                                <field name="metadata_json_text" nolabel="1" widget="text" class="oe_inline" placeholder="{}"/>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <record id="view_rollup_node_search" model="ir.ui.view">
            <field name="name">rollup.node.search</field>
            <field name="model">rollup.node</field>
            <field name="arch" type="xml">
                <search string="Search Nodes">
                    <field name="node_name"/>
                    <field name="service_id"/>
                    <filter name="status_running" string="Running" domain="[('status', '=', 'running')]"/>
                    <filter name="status_provisioning" string="Provisioning" domain="[('status', '=', 'provisioning')]"/>
                    <filter name="status_degraded" string="Degraded" domain="[('status', '=', 'degraded')]"/>
                </search>
            </field>
        </record>
    </data>
</odoo>
