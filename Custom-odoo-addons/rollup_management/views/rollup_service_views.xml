<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="action_rollup_service" model="ir.actions.act_window">
            <field name="name">Rollup Services</field>
            <field name="res_model">rollup.service</field>
            <field name="view_mode">list,kanban,form</field>
            <field name="context">{'search_default_status_active': 1}</field>
        </record>

        <record id="action_rollup_service_payment_logs" model="ir.actions.act_window">
            <field name="name">Payment Logs</field>
            <field name="res_model">stripe.payment.log</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[("rollup_service_id", "=", active_id)]</field>
            <field name="context">{'default_rollup_service_id': active_id}</field>
        </record>

        <record id="action_rollup_service_invoices" model="ir.actions.act_window">
            <field name="name">Invoices</field>
            <field name="res_model">account.move</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[("rollup_service_id", "=", active_id)]</field>
            <field name="context">{'default_rollup_service_id': active_id, 'default_move_type': 'out_invoice'}</field>
        </record>

        <record id="action_rollup_service_payments" model="ir.actions.act_window">
            <field name="name">Payments</field>
            <field name="res_model">account.payment</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[('memo', '=', context.get('default_service_id'))]</field>
            <field name="context">
        {'default_rollup_service_id': active_id, 'default_payment_type': 'inbound', 'default_partner_type': 'customer'}
            </field>
        </record>

        <record id="action_rollup_service_nodes" model="ir.actions.act_window">
            <field name="name">Service Nodes</field>
            <field name="res_model">rollup.node</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[("service_id", "=", active_id)]</field>
            <field name="context">{'default_service_id': active_id}</field>
        </record>

        <menuitem id="menu_rollup_root" name="Rollup Management" sequence="40" groups="access_rights.group_admin,access_rights.group_technical_manager,access_rights.group_support_staff,access_rights.group_support_staff_manager"/>
        <menuitem id="menu_rollup_services" name="Rollup Subscriptions" parent="menu_rollup_root" action="action_rollup_service" sequence="10" groups="access_rights.group_admin,access_rights.group_technical_manager,access_rights.group_support_staff,access_rights.group_support_staff_manager"/>

        <record id="view_rollup_service_tree" model="ir.ui.view">
            <field name="name">rollup.service.tree</field>
            <field name="model">rollup.service</field>
            <field name="arch" type="xml">
                <list string="Rollup Services">
                    <field name="name"/>
                    <field name="service_id"/>
                    <field name="chain_id"/>
                    <field name="type_id"/>
                    <field name="region_ids" widget="many2many_tags"/>
                    <field name="status" widget="badge"/>
                    <field name="subscription_status" widget="badge"/>
                    <field name="node_count"/>
                    <field name="create_date"/>
                </list>
            </field>
        </record>

