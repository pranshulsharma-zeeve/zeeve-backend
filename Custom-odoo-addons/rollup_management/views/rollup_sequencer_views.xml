<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="action_rollup_sequencer" model="ir.actions.act_window">
            <field name="name">Sequencer</field>
            <field name="res_model">rollup.sequencer</field>
            <field name="view_mode">list,form</field>
        </record>

        <menuitem id="menu_rollup_sequencer" name="Sequencers" parent="rollup_management.menu_rollup_configuration" action="action_rollup_sequencer" sequence="20" groups="access_rights.group_admin,access_rights.group_technical_manager,access_rights.group_support_staff,access_rights.group_support_staff_manager"/>

        <record id="view_rollup_sequencer_tree" model="ir.ui.view">
            <field name="name">rollup.sequencer.tree</field>
            <field name="model">rollup.sequencer</field>
            <field name="arch" type="xml">
                <list string="Sequencer">
                    <field name="logo"/>
                    <field name="name"/>
                    <field name="sa_active" widget="boolean_button"/>
                    <field name="coming_soon"/>

                </list>
            </field>
        </record>

        <record id="view_rollup_sequencer_form" model="ir.ui.view">
            <field name="name">rollup.sequencer.form</field>
            <field name="model">rollup.sequencer</field>
            <field name="arch" type="xml">
                <form string="Sequencer">
                    <sheet>
                        <group>
                            <group>
                                <field name="logo" widget="image" />
                                <field name="name"/>
                                <field name="description"/>
                            </group>
                            <group>
                                <field name="sa_active"/>
                                <field name="coming_soon"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Rollup Types">
                                <label string="Rollup Types" for="type_ids" class="o_form_label"/>
                                <field name="type_ids" widget="many2many_tags" options="{'no_create': True}"/>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <record id="view_rollup_sequencer_search" model="ir.ui.view">
            <field name="name">rollup.sequencer.search</field>
            <field name="model">rollup.sequencer</field>
            <field name="arch" type="xml">
                <search string="Search Sequencer">
                    <field name="name"/>
                    <filter name="filter_active" string="Active" domain="[('sa_active', '=', True)]"/>

                </search>
            </field>
        </record>
    </data>
</odoo>
