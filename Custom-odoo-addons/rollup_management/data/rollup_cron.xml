<?xml version="1.0" encoding="UTF-8"?>
<odoo>
  <data noupdate="1">
    <record id="ir_cron_rollup_overdue_audit" model="ir.cron">
      <field name="name">Rollup Subscription Overdue Audit</field>
      <field name="model_id" ref="rollup_management.model_rollup_service"/>
      <field name="state">code</field>
      <field name="code">model.cron_check_overdue_subscriptions()</field>
      <field name="interval_number">1</field>
      <field name="interval_type">days</field>
      <field name="active">True</field>
      <field name="user_id" ref="base.user_root"/>
    </record>
    <record id="ir_cron_rollup_subscription_reminders" model="ir.cron">
      <field name="name">Rollup Subscription Reminder Emails</field>
      <field name="model_id" ref="rollup_management.model_rollup_service"/>
      <field name="state">code</field>
      <field name="code">model.cron_send_subscription_reminders()</field>
      <field name="interval_number">1</field>
      <field name="interval_type">days</field>
      <field name="active">True</field>
      <field name="user_id" ref="base.user_root"/>
    </record>

    <record id="ir_cron_rollup_managed_billing" model="ir.cron">
      <field name="name">Rollup Managed: Billing Engine</field>
      <field name="model_id" ref="rollup_management.model_rollup_service"/>
      <field name="state">code</field>
      <field name="code">model.run_rollup_billing_cron()</field>
      <field name="interval_number">1</field>
      <field name="interval_type">days</field>
      <field name="active">False</field>
      <field name="user_id" ref="base.user_root"/>
    </record>

    <record id="ir_cron_rollup_migration_to_odoo_managed" model="ir.cron">
      <field name="name">Rollup: Migrate to Odoo Managed Billing</field>
      <field name="model_id" ref="rollup_management.model_rollup_service"/>
      <field name="state">code</field>
      <field name="code">model.cron_migrate_rollups_to_odoo_managed()</field>
      <field name="interval_number">1</field>
      <field name="interval_type">days</field>
      <field name="active">False</field>
      <field name="user_id" ref="base.user_root"/>
    </record>

  </data>
</odoo>
